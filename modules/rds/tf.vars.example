# ******************************************************
#  Basic
# ******************************************************
partner_name = "acme"
environment  = "mainnet"

# Note: vpc_id, private_subnet_ids, and private_subnet_cidr_blocks are
# resolved by the root module from the networking module or existing_vpc inputs.
vpc_id                     = "<vpc-id>"
private_subnet_ids         = ["<subnet-id-1>", "<subnet-id-2>", "<subnet-id-3>"]
private_subnet_cidr_blocks = ["<cidr-1>", "<cidr-2>", "<cidr-3>"]

# ******************************************************
#  RDS
# ******************************************************
rds = {
  enabled        = true
  db_name        = "coprocessor"
  engine_version = "17.4"

  username = "coprocessor"

  instance_class        = "db.m5.4xlarge"
  allocated_storage     = 2000
  max_allocated_storage = 3000

  multi_az                        = true
  backup_retention_period         = 30
  deletion_protection             = true
  enable_master_password_rotation = false

  # Enhanced monitoring disabled — differs from submodule default of 60.
  monitoring_interval    = 0
  create_monitoring_role = true

  allowed_cidr_blocks = ["10.0.16.0/20", "10.0.32.0/20", "10.0.48.0/20"]

  parameters = [
    {
      name  = "rds.force_ssl"
      value = "0"
    }
  ]

  # Uncomment when importing a pre-existing RDS instance to preserve its identifier
  # and prevent resource recreation.
  # identifier_override = "zama-mainnet-coprocessor"
}
