# =============================================================================
#  Basic
# =============================================================================
environment = "coprocessor-prod"
name        = "coprocessor"

tags = {
  Environment = "prod"
  Project     = "coprocessor"
  Owner       = "devops-team"
  CostCenter  = "engineering"
  Terraform   = "true"
  ManagedBy   = "terraform"
}

# =============================================================================
#  Networking
# =============================================================================
vpc_cidr = "10.0.0.0/16"

# Auto-detect AZs (limited to first 3). Uncomment to pin explicitly:
# vpc_availability_zones = ["eu-west-1a", "eu-west-1b", "eu-west-1c"]

use_subnet_calc_v2       = true
private_subnet_cidr_mask = 20
public_subnet_cidr_mask  = 24

vpc_single_nat_gateway   = false
vpc_flow_log_enabled     = false
flow_log_destination_arn = "arn:aws:s3:::zama-aws-org-vpc-flow-logs"

# Additional subnets for CNI / specific node groups
create_additional_subnets         = true
additional_subnet_cidr_mask       = 20
expose_additional_subnets_for_eks = true
additional_subnets_elb_role       = "internal"

# Route zws_pool node group through additional subnets
node_groups_using_additional_subnets = ["zws_pool"]

additional_subnet_tags = {
  Purpose = "cni-additional"
}

# =============================================================================
#  EKS Cluster
# =============================================================================
eks_cluster_version                   = "1.32"
eks_cluster_endpoint_public_access    = false
eks_cluster_endpoint_private_access   = true
eks_cluster_creator_admin_permissions = true
eks_cluster_enable_irsa               = true

# IAM roles granted cluster-admin access
eks_admin_roles_arns = []

# =============================================================================
#  EKS Addons
# =============================================================================

# Default addons (aws-ebs-csi-driver, coredns, vpc-cni, kube-proxy,
# eks-pod-identity-agent) are enabled by the module automatically.
# Add extras here if needed:
# eks_addons = {
#   aws-efs-csi-driver = { most_recent = true }
# }

eks_default_addons_config_values = {
  vpc_cni = {
    init = {
      env = {
        DISABLE_TCP_EARLY_DEMUX = "true"
      }
    }
    env = {
      ENABLE_POD_ENI                    = "true"
      POD_SECURITY_GROUP_ENFORCING_MODE = "standard"
      ENABLE_PREFIX_DELEGATION          = "true"
      WARM_PREFIX_TARGET                = "1"
    }
  }
}

# =============================================================================
#  Node Groups
# =============================================================================
eks_managed_node_group_defaults = {
  ami_type                   = "AL2023_x86_64_STANDARD"
  use_custom_launch_template = true
  disk_size                  = 50
  disk_type                  = "gp3"
}

eks_managed_node_group_default_iam_role_policies = {
  AmazonEBSCSIDriverPolicy           = "arn:aws:iam::aws:policy/service-role/AmazonEBSCSIDriverPolicy"
  AmazonEC2ContainerRegistryReadOnly = "arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryReadOnly"
  AmazonEKSWorkerNodePolicy          = "arn:aws:iam::aws:policy/AmazonEKSWorkerNodePolicy"
  AmazonSSMManagedInstanceCore       = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

eks_managed_node_groups = {
  zws_pool = {
    capacity_type  = "ON_DEMAND"
    min_size       = 1
    max_size       = 10
    desired_size   = 2
    instance_types = ["t3.xlarge"]

    update_config = {
      max_unavailable = 1
    }

    taints = {
      dedicated = {
        key    = "node.kubernetes.io/zwspool"
        value  = "true"
        effect = "NO_SCHEDULE"
      }
    }

    labels = {
      Environment = "prod"
      NodeGroup   = "zwspool"
    }

    tags = {
      NodeGroupType = "zwspool"
    }
  }

  default = {
    capacity_type  = "ON_DEMAND"
    min_size       = 1
    max_size       = 3
    desired_size   = 3
    instance_types = ["t3.xlarge"]

    update_config = {
      max_unavailable = 1
    }

    labels = {
      Environment = "prod"
      NodeGroup   = "default"
    }

    tags = {
      NodeGroupType = "default"
    }
  }
}

# =============================================================================
#  Karpenter
# =============================================================================
enable_karpenter           = true
karpenter_rule_name_prefix = "coproc"

enable_karpenter_controller_nodegroup = true

karpenter_controller_nodegroup_config = {
  capacity_type  = "ON_DEMAND"
  min_size       = 1
  max_size       = 2
  desired_size   = 1
  instance_types = ["t3.small"]
  disk_size      = 50
  disk_type      = "gp3"

  taints = {
    karpenter = {
      key    = "karpenter.sh/controller"
      value  = "true"
      effect = "NO_SCHEDULE"
    }
  }

  labels = {
    "karpenter.sh/controller" = "true"
  }
}

karpenter_node_iam_role_additional_policies = {
  AmazonSSMManagedInstanceCore = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}