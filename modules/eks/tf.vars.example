# =============================================================================
# BASIC CONFIGURATION
# =============================================================================

name        = "coprocessor"
environment = "coprocessor-prod"

tags = {
  Environment = "prod"
  Project     = "coprocessor"
  Owner       = "devops-team"
  CostCenter  = "engineering"
  Terraform   = "true"
  ManagedBy   = "terraform"
}

# =============================================================================
# NETWORK INPUTS (FROM VPC MODULE)
# =============================================================================

network = {
  vpc_id             = "vpc-1234567890abcdef0"
  private_subnet_ids = [
    "subnet-aaa",
    "subnet-bbb",
    "subnet-ccc"
  ]

  # Optional additional subnets (for karpenter / special pools)
  additional_subnet_ids = [
    "subnet-xxx",
    "subnet-yyy",
    "subnet-zzz"
  ]

  node_groups_using_additional_subnets = ["coproc_node_group"]
}

# =============================================================================
# EKS CLUSTER CONFIGURATION
# =============================================================================

cluster = {
  version                        = "1.32"
  endpoint_public_access          = false
  endpoint_private_access         = true
  endpoint_public_access_cidrs    = []
  enable_irsa                     = true
  enable_creator_admin_permissions = true
}

# =============================================================================
# ADDONS CONFIGURATION
# =============================================================================

addons = {
  # Override / extend defaults
  extra = {
    aws-efs-csi-driver = {
      most_recent = true
    }
  }

  # Optional VPC CNI config overrides
  vpc_cni = {
    enableNetworkPolicy = "true"
    warm_ip_target      = "5"
  }
}

# =============================================================================
# NODE GROUPS
# =============================================================================

node_groups = {

  defaults = {
    ami_type                   = "AL2023_x86_64_STANDARD"
    capacity_type              = "ON_DEMAND"
    instance_types             = ["t3.xlarge"]
    disk_size                  = 50
    disk_type                  = "gp3"
    use_custom_launch_template = true

    update_config = {
      max_unavailable = 1
    }

    iam_role_additional_policies = {
      AmazonEBSCSIDriverPolicy     = "arn:aws:iam::aws:policy/service-role/AmazonEBSCSIDriverPolicy"
      AmazonSSMManagedInstanceCore = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
    }
  }

  groups = {

    zws_pool = {
      min_size     = 1
      max_size     = 10
      desired_size = 2

      taints = {
        dedicated = {
          key    = "node.kubernetes.io/zwspool"
          value  = "true"
          effect = "NO_SCHEDULE"
        }
      }

      labels = {
        Environment = "prod"
        NodeGroup   = "zwspool"
      }

      tags = {
        NodeGroupType = "zwspool"
      }
    }

    default = {
      min_size     = 1
      max_size     = 3
      desired_size = 3

      labels = {
        Environment = "prod"
        NodeGroup   = "default"
      }

      tags = {
        NodeGroupType = "default"
      }
    }
  }
}

# =============================================================================
# CLUSTER ACCESS
# =============================================================================

access = {
  admin_role_arns = [
    "arn:aws:iam::123456789012:role/AdminRole"
  ]
}

# =============================================================================
# KARPENTER CONFIGURATION
# =============================================================================

karpenter = {
  enabled                                = true
  namespace                              = "karpenter"
  service_account                        = "karpenter"
  enable_controller_nodegroup            = true
  rule_name_prefix                       = "coproc"
  queue_name                             = null

  node_iam_role_additional_policies = {
    AmazonEBSCSIDriverPolicy = "arn:aws:iam::aws:policy/service-role/AmazonEBSCSIDriverPolicy"
  }
}